<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#fff"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".About">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WorldFix Lite"
            android:textSize="24dp"
            android:paddingStart="20dp"
            android:background="@drawable/head2"
            android:paddingTop="20dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="signin"
            android:layout_marginLeft="-210dp"
            android:backgroundTint="#3ebcc8"
            android:layout_marginTop="-7dp"

            android:id="@+id/signinbutton"

            />

        <Button
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="signup"
            android:layout_marginLeft="10dp"
            android:backgroundTint="#3ebcc8"
            android:layout_marginTop="-7dp"

            android:id="@+id/signupbutton"

            />

    </LinearLayout>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >


        <androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:orientation="vertical"
            app:cardBackgroundColor="@color/white"


            android:layout_marginLeft="6dp"
            android:layout_marginRight="2dp"
            app:cardElevation="-200dp"

            android:layout_marginTop="20dp"
            app:cardCornerRadius="50dp"
            >

            <EditText
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:hint="Search issues..."

                android:paddingStart="20dp"
                android:drawableStart="@drawable/search"
                android:background="@drawable/edittext"
                android:paddingTop="10dp"
                android:drawableTint="#67ef"

                android:id="@+id/search_bar"

                />













        </androidx.cardview.widget.CardView>

       <LinearLayout
           android:layout_width="match_parent"
           android:orientation="horizontal"
           android:layout_height="wrap_content">



           <Button
               android:layout_width="170dp"
               android:layout_height="wrap_content"
               android:layout_marginTop="20dp"
               android:textColor="@color/white"
               android:text="Post a problem"
               android:backgroundTint="#40d2de"
               android:layout_marginLeft="10dp"

               android:id="@+id/post_problem"

               />

           <Button
               android:layout_width="170dp"
               android:layout_height="wrap_content"
               android:layout_marginTop="20dp"
               android:textColor="@color/white"
               android:text="Solve a problem"
               android:backgroundTint="#40d2de"
               android:layout_marginLeft="40dp"

               android:id="@+id/solve_problem"

               />


       </LinearLayout>






    </LinearLayout>









</LinearLayout>